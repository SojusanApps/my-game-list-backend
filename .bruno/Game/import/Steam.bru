meta {
  name: Steam
  type: http
  seq: 1
}

get {
  url: {{protocol}}/{{host}}:{{port}}/api/game/game-lists/steam-import?steam_profile_id={{steam_profile_id}}
  body: none
  auth: basic
}

params:query {
  steam_profile_id: {{steam_profile_id}}
}

auth:basic {
  username: {{username}}
  password: {{password}}
}

settings {
  encodeUrl: true
  timeout: 0
}
