meta {
  name: Get ExternalGameSources
  type: http
  seq: 9
}

post {
  url: {{igdb_api_base_url}}/external_game_sources/
  body: text
  auth: none
}

headers {
  Client-ID: {{igdb_client_id}}
  Authorization: Bearer {{igdb_access_token}}
}

body:text {
  fields *;
  limit 100;
}

settings {
  encodeUrl: true
  timeout: 0
}
